# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# uv / virtualenv
.venv/

# Caches
.pytest_cache/
.ruff_cache/
.pyright_cache/

# Build / dist
build/
dist/
*.egg-info/

# Environment
.env
.env.local

# OS / IDE
.DS_Store
*.swp
.vscode/
.idea/

# Local dev process artifacts (LiteLLM proxy log + pid; left running per "don't stop dev servers")
.litellm/

# Runtime state (memory DB + LangGraph checkpoints — local, not committed)
.lunasre/

# iw.py controller runtime (pids + logs — local only)
.iw/

# Investigation runtime state — file-backed sessions (journal/graph/meta per investigation).
# Durable across a backend restart; local runtime data, not source. Ignore all sessions EXCEPT
# the checked-in INC-4821 demo snapshot, so a fresh clone (incl. a Windows machine) opens the
# closed flagship investigation as-is — the full journal/graph/hypotheses — WITHOUT re-running it.
engine/data/investigations/*
!engine/data/investigations/app-incident_INC-4821/
